# ─────────────────────────────────────────────────────────────────────────────
# telephony-appointments — additional environment variables
#
# These are MERGED with the parent `teventis-automations/.env` at runtime
# (server.py + vapi_assistant.py both call `load_dotenv()` which loads from
# the nearest .env walking up). In production the values live in the SAME
# .env on the server — no separate file. This template just documents what's
# needed beyond the news-automation envvars.
# ─────────────────────────────────────────────────────────────────────────────


# ── Vapi ─────────────────────────────────────────────────────────────────────
# Get this from your Vapi dashboard once Rio creates the account.
# https://dashboard.vapi.ai → Settings → API Keys
VAPI_API_KEY=your_vapi_api_key_here


# ── Calendly ────────────────────────────────────────────────────────────────
# Personal Access Token from Rio's Calendly account.
# https://calendly.com → account settings → Integrations → API & Webhooks
CALENDLY_PAT=your_calendly_personal_access_token_here


# ── Webhook ─────────────────────────────────────────────────────────────────
# Public URL Vapi will POST events to. Must be HTTPS in production.
# Local dev: use ngrok or cloudflared, e.g. https://riley.ngrok.app/vapi/webhook
TELEPHONY_WEBHOOK_URL=https://riley.teventis.com/vapi/webhook

# Shared secret. Configure the same value in Vapi's dashboard under the
# assistant's serverUrlSecret. Generate with: openssl rand -hex 32
# Leave blank in dev to skip verification (NOT recommended in prod).
TELEPHONY_WEBHOOK_SECRET=

# Local port the FastAPI service listens on. Production uses a reverse proxy
# in front of this.
TELEPHONY_PORT=8088


# ── Anthropic (already shared from parent) ──────────────────────────────────
# Set in parent .env: ANTHROPIC_API_KEY=...
# If you want a separate key just for the telephony cost line, set it here
# and update vapi_assistant.py FUNCTION_TOOLS / model config to use it.
