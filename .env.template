# ─────────────────────────────────────────────────────────────────────────────
# Teventis Automations — environment template
# Copy this to `.env` and fill in. Never commit your real `.env` to Git.
# ─────────────────────────────────────────────────────────────────────────────
#
# THIS FILE IS NOW SHORT BY DESIGN. Everything per-client lives in the database:
#   - Social handles, account IDs, modes, session paths, proxies → social_accounts
#   - Twitter / LinkedIn / Instagram secrets (encrypted)          → social_account_credentials
#   - Schedule times, timezone, dry-run, keyword filters, etc.    → automations + news_automation_configs
#
# To rotate or add a credential, log into the admin panel — not this file.
# To migrate existing legacy `.env` credentials into the DB, run:
#   python scripts/migrate_credentials_from_env.py
# ─────────────────────────────────────────────────────────────────────────────


# ── Postgres ─────────────────────────────────────────────────────────────────
# The automation runtime reloads client config + credentials from this database
# on every scheduler tick. Same DATABASE_URL used by `teventis-database`.
DATABASE_URL=postgresql://postgres@localhost:5432/teventis_dev


# ── Master encryption key ────────────────────────────────────────────────────
# Used to encrypt/decrypt every row in social_account_credentials via Postgres
# pgcrypto. Generate ONCE per environment and back it up — losing it means every
# stored credential becomes unrecoverable.
#
# Generate with:  openssl rand -hex 32
TEVENTIS_SECRETS_KEY=replace_me_with_openssl_rand_hex_32


# ── Shared service keys (NOT per-client) ─────────────────────────────────────
# These are global Teventis-wide accounts used across all clients.
# Cost: NewsAPI free tier (100 req/day), Anthropic pay-per-use.

# Sign up at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── News scheduler ───────────────────────────────────────────────────────────
# Seconds between DB reload + schedule checks (clamped 5–120). Default 10.
# Lower = admin UI changes apply sooner; higher = less database load.
# SCHEDULER_POLL_SECONDS=10
#
# After each article, if every platform fails, try the next freshest candidate
# in the same run (clamped 1–15). Default 3. Failed URLs stay in DB → skipped later.
# MAX_ARTICLE_ATTEMPTS_PER_RUN=3


# ── Telephony (Riley AI phone agent) ─────────────────────────────────────────
# Only required if running the telephony-appointments service. See
# `telephony-appointments/.env.template` for the full annotated set.

# Vapi — get from https://dashboard.vapi.ai → Settings → API Keys
VAPI_API_KEY=your_vapi_api_key_here

# Calendly — Personal Access Token from Rio's account
# https://calendly.com → settings → Integrations → API & Webhooks
CALENDLY_PAT=your_calendly_personal_access_token_here

# Public URL Vapi posts call events to.
TELEPHONY_WEBHOOK_URL=https://riley.teventis.com/vapi/webhook

# Shared secret — set the same value in Vapi's assistant config.
# Generate with: openssl rand -hex 32
TELEPHONY_WEBHOOK_SECRET=

# Local port for the FastAPI service (Caddy/nginx forwards to this).
TELEPHONY_PORT=8088


# ── Internal lead gen (Places / HubSpot / enrichment — add as pipeline grows) ─
# GCP: enable Places API (New) on this key → console.cloud.google.com
# GOOGLE_PLACES_API_KEY=your_server_restricted_maps_key_here
# Ingest to Postgres:  python internal-lead-gen/ingest_maps.py  (needs DATABASE_URL)

# Hunter.io, HubSpot Private App tokens, etc. — wire here or in Postgres when integrated.
