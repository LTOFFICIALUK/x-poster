# ─────────────────────────────────────────────────────────
# News Automation — API Keys Template
# Copy this file to `.env` and fill in your credentials.
# Never commit your real .env file to Git.
# ─────────────────────────────────────────────────────────

# ── News API ──────────────────────────────────────────────
# Sign up free at https://newsapi.org
# Free tier: 100 requests/day (plenty for 3 posts/day)
NEWS_API_KEY=your_newsapi_key_here

# ── Anthropic (Claude AI) ─────────────────────────────────
# Get your key at https://console.anthropic.com
# Used to generate neutral post summaries
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Twitter / X ───────────────────────────────────────────
# Apply at https://developer.twitter.com
# You need a Free or Basic tier developer account.
# Create a project & app, then generate all four keys below.
# Note: Free tier allows 1,500 tweets/month (50/day — fine for us)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ── LinkedIn ──────────────────────────────────────────────
# Register an app at https://www.linkedin.com/developers
# Request the "Share on LinkedIn" and "Sign In with LinkedIn" products.
# Generate an OAuth 2.0 access token with w_member_social scope.
# LINKEDIN_PERSON_URN: Your LinkedIn member URN — found via the /v2/me API endpoint
# e.g. urn:li:person:ABC123xyz
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID_HERE

# ── Instagram (Meta Graph API) ────────────────────────────
# Requires: Facebook Business account + Instagram Professional account
# Steps: https://developers.facebook.com → Create App → Add Instagram Graph API
# You need a long-lived Page Access Token and your Instagram Account ID.
# Note: Instagram REQUIRES an image with every post. The script uses the
# article's image (if available) or a placeholder graphic.
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# ── Options ───────────────────────────────────────────────
# Set DRY_RUN=true to test the script without actually posting anything
# All generated posts will be printed to the console/log only.
DRY_RUN=false
